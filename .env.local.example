# Resend (https://resend.com) — used by app/api/contact/route.ts to deliver
# the Contact page form to info@hutnharvest.com.
RESEND_API_KEY=re_your_api_key_here

# Must be an address on a domain you've verified in Resend.
RESEND_FROM_EMAIL=Hut & Harvest <contact@hutnharvest.com>

# Where submitted messages are delivered.
CONTACT_TO_EMAIL=info@hutnharvest.com
