# Sends Contact and Books Health Check form submissions via Gmail SMTP,
# authenticated as your own Google Workspace account.
#
# GMAIL_USER: the mailbox that sends the notification (e.g. info@hutnharvest.com).
# GMAIL_APP_PASSWORD: a 16-character App Password generated at
# myaccount.google.com/apppasswords (requires 2-Step Verification enabled).
# Never use your regular account password here.
GMAIL_USER=info@hutnharvest.com
GMAIL_APP_PASSWORD=your16charapppassword

# Where submitted messages are delivered.
CONTACT_TO_EMAIL=info@hutnharvest.com
